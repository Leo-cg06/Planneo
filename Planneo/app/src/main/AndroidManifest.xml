<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_planneo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_planneo_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Trailov2">
        <activity
            android:name=".activities.WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.Trailov2">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".activities.LoginActivity" android:exported="false" />
        <activity android:name=".MainActivity" android:exported="false" />
        <activity android:name=".activities.RegisterActivity" android:exported="false" />
        <activity android:name=".activities.LugaresActivity" android:exported="false" />
        <activity android:name=".activities.EventoActivity" android:exported="false" />
        <activity android:name=".activities.PerfilActivity" android:exported="false" />
        <activity android:name=".activities.DetalleLugarActivity" android:exported="false" />
        <activity android:name=".activities.DetalleEventoActivity" android:exported="false" />
        <activity android:name=".activities.ValorarActivity" android:exported="false" />
        <activity android:name=".activities.VerResenasActivity" android:exported="false" />

    </application>
</manifest>